{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HanzoRazer/ground-water-hydraulics-ossf/schemas/ossf-site-case-1.1.0.schema.json",
  "title": "OSSF Site Case (SiteCaseV1 / 1.1.0)",
  "description": "Canonical, versioned, unit-explicit governed input contract for OSSF groundwater screening (OSSF-GW-002 + OSSF-GW-003 evidence layer). Every dimensional field carries its canonical unit in its name. Operational values are enumerated; free-form text carries no operational meaning. Load-bearing fields require evidence[] + field_bindings[].",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "site_id",
    "project",
    "regulatory_location",
    "treatment",
    "source",
    "subsurface",
    "groundwater",
    "receptors",
    "constituents",
    "physics"
  ],
  "properties": {
    "schema_version": {
      "const": "ossf-site-case-1.1.0",
      "description": "Input schema identifier. Must be exactly this value."
    },
    "site_id": {
      "$ref": "#/$defs/stableId",
      "description": "Stable site identifier (e.g. EX-001)."
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "regulatory_location": {
      "$ref": "#/$defs/regulatoryLocation"
    },
    "treatment": {
      "$ref": "#/$defs/treatment"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "subsurface": {
      "$ref": "#/$defs/subsurface"
    },
    "groundwater": {
      "$ref": "#/$defs/groundwater"
    },
    "receptors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/receptor"
      },
      "description": "Receptors evaluated. At least one required."
    },
    "constituents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/constituent"
      },
      "description": "Constituents evaluated. At least one required."
    },
    "physics": {
      "$ref": "#/$defs/physics"
    },
    "reporting": {
      "$ref": "#/$defs/reporting"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceRecord"
      },
      "description": "Evidence records supporting field bindings (OSSF-GW-003)."
    },
    "field_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fieldBinding"
      },
      "description": "Bindings from canonical field paths to evidence (OSSF-GW-003)."
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$",
      "description": "Non-empty stable identifier."
    },
    "optionalText": {
      "type": [
        "string",
        "null"
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "engineer",
        "county",
        "regulatory_authority"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "engineer": {
          "type": "string",
          "minLength": 1
        },
        "county": {
          "type": "string",
          "minLength": 1
        },
        "regulatory_authority": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "regulatoryLocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "edwards_aquifer_recharge_zone": {
          "type": "boolean"
        },
        "edwards_aquifer_transition_zone": {
          "type": "boolean"
        },
        "edwards_aquifer_contributing_zone": {
          "type": "boolean"
        },
        "karst_terrain": {
          "type": "boolean"
        },
        "coastal_zone": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "treatment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "treatment_level",
        "disinfection_status"
      ],
      "properties": {
        "treatment_level": {
          "enum": [
            "primary",
            "secondary",
            "advanced_secondary"
          ]
        },
        "disinfection_status": {
          "enum": [
            "none",
            "disinfected"
          ]
        },
        "disinfection_method": {
          "enum": [
            "none",
            "chlorine",
            "uv",
            "ozone",
            "other"
          ]
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_flow_gpd"
      ],
      "properties": {
        "design_flow_gpd": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Design flow [gallons per day]; must be positive."
        },
        "description": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "subsurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "soil_id",
        "soil_thickness_m"
      ],
      "properties": {
        "soil_id": {
          "$ref": "#/$defs/stableId",
          "description": "Soil database key."
        },
        "soil_thickness_m": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Unsaturated-zone thickness [metres]."
        }
      }
    },
    "groundwater": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "depth_to_groundwater_m",
        "hydraulic_gradient"
      ],
      "properties": {
        "depth_to_groundwater_m": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Depth to groundwater [metres]."
        },
        "hydraulic_gradient": {
          "type": "number",
          "minimum": 0,
          "description": "Hydraulic gradient [dimensionless]."
        }
      }
    },
    "receptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receptor_id",
        "receptor_type",
        "distance_m",
        "display_name"
      ],
      "properties": {
        "receptor_id": {
          "$ref": "#/$defs/stableId"
        },
        "receptor_type": {
          "enum": [
            "private_well",
            "public_well",
            "property_boundary",
            "surface_water"
          ]
        },
        "distance_m": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Source-to-receptor distance [metres]."
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "active": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "constituent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constituent_id",
        "role"
      ],
      "properties": {
        "constituent_id": {
          "$ref": "#/$defs/stableId",
          "description": "Constituent database key."
        },
        "role": {
          "enum": [
            "gating",
            "reference_only"
          ]
        },
        "source_concentration": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "description": "Explicit source concentration in the constituent's canonical unit; null selects the governed default via use_governed_default."
        },
        "use_governed_default": {
          "type": "boolean"
        },
        "source_basis": {
          "enum": [
            "measured",
            "documented",
            "database_derived",
            "assumed",
            "regulatory_default"
          ],
          "description": "ProvenanceClass for the source term (legacy EvidenceBasis mapped at parse)."
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "physics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "dispersivity_method"
      ],
      "properties": {
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "dispersivity_method": {
          "enum": [
            "epa_ssg",
            "xu_eckstein"
          ]
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comparison_soil_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stableId"
          },
          "description": "Soil IDs for the comparison-soil report section."
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "description",
        "basis",
        "status"
      ],
      "properties": {
        "assumption_id": {
          "$ref": "#/$defs/stableId"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "basis": {
          "enum": [
            "measured",
            "estimated",
            "literature",
            "regulatory_default",
            "assumed"
          ]
        },
        "status": {
          "enum": [
            "assumed",
            "verified",
            "pending_verification"
          ]
        }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "provenance_class",
        "confidence",
        "review_status",
        "source_description"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/stableId"
        },
        "provenance_class": {
          "enum": [
            "measured",
            "documented",
            "database_derived",
            "assumed",
            "regulatory_default"
          ]
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "review_status": {
          "enum": [
            "pending_review",
            "accepted",
            "rejected",
            "superseded"
          ]
        },
        "source_description": {
          "type": "string",
          "minLength": 1
        },
        "captured_date": {
          "$ref": "#/$defs/optionalText"
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        },
        "database_id": {
          "$ref": "#/$defs/optionalText"
        },
        "regulatory_authority": {
          "$ref": "#/$defs/optionalText"
        }
      }
    },
    "fieldBinding": {
      "type": "object",
      "additionalProperties": false,
      "description": "Field evidence binding. Exactly one resolution route must be non-null: evidence_id XOR database_id XOR regulatory_authority.",
      "required": [
        "field_path",
        "provenance_class",
        "review_status"
      ],
      "properties": {
        "field_path": {
          "type": "string",
          "minLength": 1
        },
        "provenance_class": {
          "enum": [
            "measured",
            "documented",
            "database_derived",
            "assumed",
            "regulatory_default"
          ]
        },
        "review_status": {
          "enum": [
            "pending_review",
            "accepted",
            "rejected",
            "superseded"
          ]
        },
        "evidence_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
        },
        "database_id": {
          "$ref": "#/$defs/optionalText"
        },
        "regulatory_authority": {
          "$ref": "#/$defs/optionalText"
        },
        "assumption_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
        },
        "notes": {
          "$ref": "#/$defs/optionalText"
        }
      },
      "oneOf": [
        {
          "description": "Route: linked evidence record",
          "required": ["evidence_id"],
          "properties": {
            "evidence_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
            },
            "database_id": {
              "type": "null"
            },
            "regulatory_authority": {
              "type": "null"
            }
          }
        },
        {
          "description": "Route: standalone database citation",
          "required": ["database_id"],
          "properties": {
            "evidence_id": {
              "type": "null"
            },
            "database_id": {
              "type": "string",
              "minLength": 1
            },
            "regulatory_authority": {
              "type": "null"
            }
          }
        },
        {
          "description": "Route: standalone regulatory citation",
          "required": ["regulatory_authority"],
          "properties": {
            "evidence_id": {
              "type": "null"
            },
            "database_id": {
              "type": "null"
            },
            "regulatory_authority": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
